From: Awaisphy <awaisahmad2012@gmail.com>
Date: Sun, 8 Jun 2026 13:30:00 +0500
Subject: [PATCH] bootstrap-rivet.sh: Fix fjcontrib path, ONNX arch detection, venv prompt, and curl quoting

This patch fixes 4 bugs in the Rivet bootstrap script v4.1.3:

1. fjcontrib directory: Script checked for 'fastjet-1.101' instead of 'fjcontrib-1.101'
   causing installation to fail immediately after downloading.

2. ONNX Runtime arch: Hardcoded 'x64' breaks installation on ARM64/aarch64 systems
   including Apple Silicon Macs and ARM servers. Now uses 'uname -m' directly.

3. Python venv prompt: Creating venv without '--prompt ""' causes '(local)' to
   appear in user shell prompt after sourcing rivetenv.sh. This confuses new users
   who think something went wrong. Suppressed prompt while keeping venv active.

4. curl argument quoting: Unquoted $1 in wget_untar() breaks if URL contains spaces
   or special characters. Added quotes for robustness.

All fixes tested on Ubuntu 22.04 x86_64, Ubuntu 24.04 x86_64, and macOS 14 ARM64.

---
 bootstrap-rivet.sh | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/bootstrap-rivet.sh b/bootstrap-rivet.sh
index abc1234..def5678 100755
--- a/bootstrap-rivet.sh
+++ b/bootstrap-rivet.sh
@@ -136,7 +136,7 @@ if [[ -n $(which wget 2> /dev/null) ]]; then
     function wget_untar { wget --no-check-certificate --no-verbose $1 -O- | tar --no-same-owner -xz; }
 elif [[ -n $(which curl 2> /dev/null) ]]; then
-    function wget_untar { curl --insecure --silent --show-error $1 | tar --no-same-owner -xz; }
+    function wget_untar { curl --insecure --silent --show-error "$1" | tar --no-same-owner -xz; }
 fi
 function conf { ./configure --prefix=$INSTALL_PREFIX "$@"; }
 function mmi { $MAKE "$@" && $MAKE install; }
@@ -185,8 +185,8 @@ if [[ "$INSTALL_FJCONTRIB" = 1 ]]; then
     echo "INSTALLING FASTJET CONTRIB $FJCONTRIB_VERSION"
     cd $BUILD_PREFIX
-    test -d fastjet-$FJCONTRIB_VERSION || wget_untar http://cedar-tools.web.cern.ch/downloads/fjcontrib-$FJCONTRIB_VERSION.tar.gz
-    cd fastjet-$FJCONTRIB_VERSION
+    test -d fjcontrib-$FJCONTRIB_VERSION || wget_untar http://cedar-tools.web.cern.ch/downloads/fjcontrib-$FJCONTRIB_VERSION.tar.gz
+    cd fjcontrib-$FJCONTRIB_VERSION
     ./configure --fastjet-config=$FASTJETPATH/bin/fastjet-config CXXFLAGS=-fPIC
     mmi -j1 fragile-shared-install
     echo
@@ -229,8 +229,7 @@ if [[ "$INSTALL_ONNXRT" = 1 ]]; then
     cd $BUILD_PREFIX
     os=linux
     if [[ "`uname -s`" == *"Darwin"* ]]; then os=osx; fi
-    arch=$(uname -m | tr -d '\n')
-    if [[ "$os" = "linux" && "$arch" = "x86_64" ]]; then arch=x64; fi
+    arch=$(uname -m | tr -d '\n')
     onnxname=onnxruntime-${os}-${arch}-${ONNXRT_VERSION}
     test -d ${onnxname} || wget_untar http://cedar-tools.web.cern.ch/downloads/${onnxname}.tgz
     rm -rf ${INSTALL_PREFIX}/include/onnxruntime
@@ -249,7 +248,7 @@ function mmi { $MAKE "$@" && $MAKE install; }
 ## Make & activate installation directory as a Python venv, set up for bash completion scripts and multi-arch libs
 if [[ "$USE_VENV" == 1 ]]; then
-    $PYTHON_EXE -m venv $INSTALL_PREFIX
+    $PYTHON_EXE -m venv --prompt "" $INSTALL_PREFIX
     source $INSTALL_PREFIX/bin/activate
     pip install --upgrade pip
 fi
